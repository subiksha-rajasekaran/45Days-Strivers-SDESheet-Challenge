class Solution {
public:
    vector<int> nextSmallerElements(const vector<int>& arr) {
        vector<int>nse(arr.size());
        stack<int>st;
        for(int i=arr.size()-1;i>=0;i--){
            while(!st.empty() && st.top()>=arr[i]) st.pop();
            if(st.empty()) nse[i]=-1;
            else  nse[i]=st.top();
            st.push(arr[i]);
        }
        return nse;
    }
};
