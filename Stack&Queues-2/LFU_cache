class LFUCache {
public:
    class Node{
        public:
            int key,val,cnt;Node*prev,*next;
            Node(int _key,int _val){
                key=_key;
                val=_val;
                cnt=1;
        }};
    class List{
        public:
            Node*head,*tail;int size;
            List(){
                head=new Node(0,0);
                tail=new Node(0,0);
                head->next=tail;
                tail->prev=head;
                size=0;
        }
        void Addfront(Node*newnode){
            Node*temp=head->next;
            newnode->prev=head;
            newnode->next=temp;
            head->next=newnode;
            temp->prev=newnode;
            size++;
        }
        void removenode(Node*delnode){
            Node*delprev=delnode->prev;
            Node*delnext=delnode->next;
            delprev->next=delnext;
            delnext->prev=delprev;
            size--;
        }  
    };  
    unordered_map<int,Node*>keynode;
    unordered_map<int,List*>freqlist;
    int maxsize,currsize,minfreq;
    LFUCache(int capacity){
        maxsize=capacity;
        minfreq=0;
        currsize=0;
    }
    void update(Node*node){
        keynode.erase(node->key);
        freqlist[node->cnt]->removenode(node);
        if(node->cnt==minfreq && freqlist[node->cnt]->size==0) minfreq++;
        node->cnt++;
        List* nexthigher;
        if(freqlist.find(node->cnt)!=freqlist.end()){
            nexthigher=freqlist[node->cnt];
        }
        else{
        nexthigher=new List();
        freqlist[node->cnt]=nexthigher;
        }
        nexthigher->Addfront(node);
        keynode[node->key]=node;
    }   
    int get(int key) {
        if(keynode.find(key)==keynode.end()) return -1;
        Node*node=keynode[key];
        int el=node->val;
        update(node);
        return el;        
    }    
    void put(int key, int value) {
        if(maxsize==0) return;
        if(keynode.find(key)!=keynode.end()){
            Node*node=keynode[key];
            node->val=value;
            update(node);
        }
        else{
            if(currsize==maxsize){
                List*list=freqlist[minfreq];
                Node* delnode=list->tail->prev;
                keynode.erase(delnode->key);
                list->removenode(delnode);
                delete delnode;
                currsize--;
            }
            currsize++;
            minfreq=1;
            List*listfreq;
            if(freqlist.find(minfreq)!=freqlist.end()){
                listfreq=freqlist[minfreq];
            }
            else{
                listfreq=new List();
                freqlist[minfreq]=listfreq;
            }
            Node*node=new Node(key,value);
            listfreq->Addfront(node);
            keynode[key]=node;
        }
    }
};

